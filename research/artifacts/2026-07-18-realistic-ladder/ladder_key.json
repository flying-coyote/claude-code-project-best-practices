   }
  },
  "term-cap-python": {
   "rtype": "terminology",
   "check": {
    "kind": "prose_bans_regex",
    "file": "README.md,CHANGELOG.md",
    "pattern": "(?<![\\w./-])python(?![\\w.-])"
   }
  },
  "term-macos": {
   "rtype": "terminology",
   "check": {
    "kind": "prose_bans_regex",
    "file": "README.md,CHANGELOG.md",
    "pattern": "\\bMacOS\\b|\\bMac OS\\b"
   }
  },
  "content-mit": {
   "rtype": "required-content",
   "check": {
    "kind": "prose_requires_regex",
    "file": "README.md",
    "pattern": "\\bMIT License\\b",
    "min": 1
   }
  },
