 "rules": {
  "term-digest": {
   "rtype": "terminology",
   "check": {
    "kind": "prose_requires_regex",
    "file": "README.md",
    "pattern": "\\bdigest\\b",
    "min": 2
   }
  },
  "term-source-table": {
   "rtype": "terminology",
   "check": {
    "kind": "prose_requires_regex",
    "file": "README.md",
    "pattern": "\\bsource table\\b",
    "min": 1
   }
  },
  "term-numeric-fields": {
   "rtype": "terminology",
   "check": {
    "kind": "prose_requires_regex",
    "file": "README.md",
    "pattern": "\\bnumeric fields?\\b",
    "min": 1
   }
  },
  "term-cap-lumen": {
   "rtype": "terminology",
   "check": {
    "kind": "custom",
    "fn": "cap_lumen"
   }
  },
  "term-cap-csv": {
   "rtype": "terminology",
   "check": {
    "kind": "prose_bans_regex",
    "file": "README.md,CHANGELOG.md",
    "pattern": "(?<![\\w./-])csv(?![\\w.-])"
   }
  },
  "term-cap-json": {
   "rtype": "terminology",
   "check": {
    "kind": "prose_bans_regex",
    "file": "README.md,CHANGELOG.md",
